  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "rootView": {
      "viewName": "contadores.view.List",
      "type": "XML",
      "id": "ListView"
    }
  }
}